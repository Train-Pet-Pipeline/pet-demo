{
  "name": "playground",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "next dev -p 3200",
    "build": "next build",
    "start": "next start -p 3200",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "perf": "pnpm build && lhci autorun --config=./lhci.config.cjs"
  },
  "dependencies": {
    "@purrai/theme": "workspace:*",
    "@purrai/ui": "workspace:*",
    "next": "14.2.3",
    "next-intl": "3.26.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "1.50.0",
    "@testing-library/jest-dom": "6.4.5",
    "@testing-library/react": "15.0.7",
    "@types/node": "20.12.12",
    "@types/react": "18.3.2",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.3",
    "eslint-plugin-frontends": "workspace:*",
    "jsdom": "24.0.0",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.3",
    "typescript": "5.4.5",
    "vitest": "1.5.0",
    "@lhci/cli": "0.14.0",
    "@axe-core/playwright": "4.9.1"
  }
}
